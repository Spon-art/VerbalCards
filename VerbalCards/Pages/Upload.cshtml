@page "/Upload"
@model VerbalCards.Pages.Upload
@{
    ViewData["Title"] = "Upload - VerbalCards";
    Layout = "Shared/_Layout";
}

<div class="center">

    <h2>Upload an MP3 file</h2>

    <form id="uploadForm" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="file" name="AudioFile" accept=".mp3,audio/mpeg,audio/wav,audio/x-wav,audio/wave" />
        <br/><br/>
        <button type="submit">Upload</button>
    </form>

    @if (Model.UploadResult != null)
    {
        <p>Status: @Model.UploadResult.StatusCode</p>
        <p>Audio ID: @Model.UploadResult.AudioId</p>
        
        <!-- Add Transcribe button that appears after upload -->
        <button id="transcribeBtn" 
                class="btn btn-primary" 
                data-audio-id="@Model.UploadResult.AudioId">
            Transcribe Audio
        </button>
        
        <!-- Add a div to display transcription result -->
        <div id="transcriptionResult" style="margin-top: 20px; display: none;">
            <h3>Transcription:</h3>
            <p id="transcriptionText"></p>
        </div>
        
        <!-- Add loading indicator -->
        <div id="loadingSpinner" style="display: none;">
            <p>Transcribing... Please wait.</p>
        </div>
    }

