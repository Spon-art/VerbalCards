@page "/Transcribe"
@model VerbalCards.Pages.TranscribeModel

@{
    ViewData["Title"] = "Transcribe - VerbalCards";
    Layout = "Shared/_Layout";
}

<div class="center">

    <h2>Transcribe Audio</h2>

    <form id="transcribeForm">
        @Html.AntiForgeryToken()

        <input type="text"
               name="audioId"
               placeholder="Enter Audio ID"
               required />

        <br/><br/>

        <button type="submit">Start Transcription</button>
    </form>

    <br/>

    <div id="statusBox"></div>

    <div id="resultBox" style="margin-top:20px;font-weight:bold;"></div>

</div>

<script>
    document.getElementById("transcribeForm").addEventListener("submit", async (e) => {
        e.preventDefault();

        const audioId = e.target.audioId.value;

        document.getElementById("statusBox").innerText =
            "Starting transcription...";

        // Call backend endpoint
        const response = await fetch(`/audio/${audioId}/transcribe`, {
            method: "POST"
        });

        const jobData = await response.json();

        if (!jobData.job_id) {
            document.getElementById("statusBox").innerText =
                "Failed to start transcription";
            return;
        }

        pollStatus(jobData.job_id);
    });

    async function pollStatus(jobId) {

        const statusBox = document.getElementById("statusBox");
        const resultBox = document.getElementById("resultBox");

        while (true) {

            const response = await fetch(
                `http://asr:8000/transcribe/status/${jobId}`
            );

            const data = await response.json();

            statusBox.innerText = "Status: " + data.status;

            if (data.status === "done") {
                resultBox.innerText = "Transcription: " + data.result;
                break;
            }

            if (data.status === "failed") {
                resultBox.innerText = "Transcription failed";
                break;
            }

            await new Promise(r => setTimeout(r, 2000));
        }
    }
</script>