@page "/Grid"
@model VerbalCards.Pages.Grid
@{
    ViewData["Title"] = "Grid - VerbalCards";
    Layout = "Shared/_Layout";
}

<div class="center_blank">
    <h2>Download audio files shown in grid</h2>
    
    <br/>
    
    <div class="container">
        @foreach (var item in Model.AudioItems)
        {
            <div class="item pink">
                <p>@item.Filename</p>
                <audio controls>
                    <source src="/audio/get/@item.Id" type="@item.ContentType">
                    Your browser does not support the audio element.
                </audio>
                <!-- Add Transcribe button that appears after upload -->
                <button id="transcribeBtn" 
                        class="btn btn-primary" 
                        data-audio-id="@item.Id">
                    Transcribe Audio
                </button>
                <!-- Add a div to display transcription result -->
                <div id="transcriptionResult" style="margin-top: 20px; display: none;">
                    <h3>Transcription:</h3>
                    <p id="transcriptionText"></p>
                </div>
                <!-- Add loading indicator -->
                <div id="loadingSpinner" style="display: none;">
                    <p>Transcribing... Please wait.</p>
                </div>
            </div>
        }
    </div>
</div>

<script>
    document.getElementById('transcribeBtn')?.addEventListener('click', async function() {
        const audioId = this.dataset.audioId;
        const transcribeBtn = this;
        const spinner = document.getElementById('loadingSpinner');
        const resultDiv = document.getElementById('transcriptionResult');
        const transcriptionText = document.getElementById('transcriptionText');
        
        transcribeBtn.disabled = true;
        spinner.style.display = 'block';
        resultDiv.style.display = 'none';
        
        try {
            // First, fetch the audio file from your server as a blob
            const audioResponse = await fetch(`/audio/get/${audioId}`);
            
            if (!audioResponse.ok) {
                throw new Error(`Failed to fetch audio: ${audioResponse.status}`);
            }
            
            // Get the audio data as a blob
            const audioBlob = await audioResponse.blob();
            
            // Create a File object from the blob (with a filename)
            const fileName = audioResponse.headers.get('content-disposition') 
                ?.split('filename=')[1]?.replace(/"/g, '') || 'audio.wav';
            
            const file = new File([audioBlob], fileName, { 
                type: audioBlob.type || 'audio/wav' 
            });
            
            // Create form data for the FastAPI endpoint
            const formData = new FormData();
            formData.append('file', file);
            
            // Call FastAPI directly
            const fastApiResponse = await fetch('http://localhost:8000/transcribe', {
                method: 'POST',
                body: formData,
                mode: 'cors' // Explicitly set CORS mode
            });
            
            if (!fastApiResponse.ok) {
                throw new Error(`Transcription failed: ${fastApiResponse.status}`);
            }
            
            const result = await fastApiResponse.json();
            
            transcriptionText.textContent = result.transcription;
            resultDiv.style.display = 'block';
            
        } catch (error) {
            console.error('Transcription error:', error);
            alert('Error: ' + error.message);
        } finally {
            transcribeBtn.disabled = false;
            spinner.style.display = 'none';
        }
    });
</script>

<style>
    .btn-primary {
        background-color: #007bff;
        color: white;
        padding: 5px 10px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        margin-top: 10px;
    }
    
    .btn-primary:hover {
        background-color: #0056b3;
    }
    
    .btn-primary:disabled {
        background-color: #cccccc;
        cursor: not-allowed;
    }
    
    #loadingSpinner {
        margin-top: 20px;
        color: #666;
    }
    
    #transcriptionResult {
        margin-top: 10px;
        padding: 5px;
        background-color: #f8f9fa;
        border-radius: 4px;
        border: 1px solid #dee2e6;
    }
</style>