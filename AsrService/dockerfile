# Simplified Dockerfile for Røst-315m ASR Model
FROM python:3.10-slim

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    cmake \
    git \
    curl \
    libsndfile1 \
    ffmpeg \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir torch torchvision torchaudio && \
    pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Pre-download the model during build (this is where the magic happens!)
RUN python -c "from transformers import pipeline; pipeline(model='alexandrainst/roest-315m')"

# Default command
CMD ["python", "asr_service.py"]